<RamblingMan>

<conditional>
<if cond="mod_loaded('Telrics_Horses_V2') and mod_version('Telrics_Horses_V2') >= version(2,5,0,0) and game_version() >= version(1,2,5)">

<append xpath="entity_classes/entity_class[@name='playerMale']">

<!-- Trigger buff to add Starting Horse Bundle.  -->	
	<effect_group name="action_AddStartingHorseBundleFTLR">
		<triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" target="self" buff="buff_action_AddStartingHorseBundleFTLR" />
	</effect_group>
</append>



</if>
</conditional>

<conditional>
<if cond="mod_loaded('Telrics_Horses_V2') and mod_version('Telrics_Horses_V2') >= version(2,5,0,0) and game_version() >= version(1,3,0)">

<!-- 3.0.1.1 -->
<!-- Explosion. fix -->

<remove xpath="/entity_classes/entity_class[starts-with(@name, 'vehicle') and contains(@name, 'Horse')]/property[starts-with(@name,'Explosion.')]"/>

<remove xpath="/entity_classes/entity_class[starts-with(@name, 'vehicle') and contains(@name, 'Horse')]/property[@name='LootListAlive']"/>

<append xpath="/entity_classes/entity_class[starts-with(@name, 'vehicle') and contains(@name, 'Horse')]">
<property name="LootList" value="vehicleMinibike"/></append>

<append xpath="/entity_classes/entity_class[starts-with(@name, 'vehicle') and contains(@name, 'Horse')]">
	<property class="Explosion">
		<property name="ParticleIndex" value="0"/>
		<property name="RadiusBlocks" value="5"/>
		<property name="RadiusEntities" value="5"/>
		<property name="BlockDamage" value="1"/>
		<property name="EntityDamage" value="1"/>
	</property>
</append>

</if>
</conditional>
</RamblingMan>