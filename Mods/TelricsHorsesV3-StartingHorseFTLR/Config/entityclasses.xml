<RamblingMan>

<conditional>
<if cond="mod_loaded('Telrics_Horses_V3') and game_version() >= version(1,3,0)">

<append xpath="entity_classes/entity_class[@name='playerMale']">

<!-- Trigger buff to add Starting Horse Bundle.  -->	
	<effect_group name="action_AddStartingHorseBundleFTLR">
		<triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" target="self" buff="buff_action_AddStartingHorseBundleFTLR" />
	</effect_group>
</append>

</if>
</conditional>

</RamblingMan>